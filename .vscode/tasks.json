{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Spring Boot API",
      "type": "shell",
      "command": ".\\mvnw.cmd spring-boot:run",
      "windows": {
        "command": ".\\mvnw.cmd spring-boot:run"
      },
      "linux": {
        "command": "./mvnw spring-boot:run"
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "${env:JAVA_HOME}"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "spring-boot",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Started PortfolioApiApplication"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "portfolio-servers"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
